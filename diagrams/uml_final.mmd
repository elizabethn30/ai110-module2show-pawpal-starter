classDiagram
    class Owner {
        -string name
        -string id
        -list~Pet~ pets
        +addPet(Pet)
        +removePet(Pet)
        +getPets() list~Pet~
    }

    class Pet {
        -string name
        -string id
        -Owner owner
        -list~Task~ tasks
        +addTask(Task)
        +removeTask(Task)
        +getTasks() list~Task~
        +getTaskById(string) Task
        +getOwner() Owner
    }

    class Task {
        -string id
        -string description
        -datetime dueDateTime
        -string frequency
        -string status
        -boolean isCompleted
        -Pet pet
        +updateStatus(string)
        +markComplete()
        +getDescription() string
        +getDueDateTime() datetime
    }

    class Scheduler {
        -list~Pet~ pets
        +addPet(Pet)
        +removePet(Pet)
        +getAllTasks() list~Task~
        +getTasksByStatus(string) list~Task~
        +getOverdueTasks() list~Task~
        +getTasksForPet(Pet) list~Task~
        +sortByTime() list~Task~
        +filterTasks(string, boolean) list~Task~
        +checkConflicts() list~string~
    }

    Owner "1" --> "*" Pet
    Pet "1" --> "*" Task
    Scheduler --> "*" Pet
